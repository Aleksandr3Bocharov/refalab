# *******************************************************************
# refalabclg
# compile from refal to object file + link + go
# arg: $1 - name of refal programm (without ext ref)
# result: running of $1.exe 
# *******************************************************************

bin/refalabc $1 -a,"-o $1.o" > $1.log
clang -o $1 $1.o lib/obj/refalab_initiator.o -Llib -lrefalab >> $1.log
$1
