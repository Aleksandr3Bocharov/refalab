$START TEST4;

$ENTRY Go;
$EXTERN First, Last, LengR, LengW, Prout, Proutm;
$EMPTY Pus, Em1, Em2, Em3;

$SPEC Bspe '2134' Pus;

$FUNC Go
{
    = 
        <Prspe Pus 'as01a432l7l' Em3>
        <Dal>;
}

//      prowerka  specifikacii
$FUNC Prspe
{
    e.E s(Em1 Em2 Em3).S = 
        <Prout ' symbol-&em' s.S>
        <Prspe e.E>;
    s(:Bspe:).S e.K =
        <Prout ' symbol-1234p=' s.S>
        <Prspe e.K>;
    $RIGHT e.H s('l7').S = 
        <Prout ' symbol-l7=' s.S>
        <Prspe e.H>;
    s.S e.K = 
        <Prout '  symbol =' s.S> 
        <Prspe e.K>;
    = ;
}

$FUNC Dal
{
    = 
        <Prln 0 1 '345678'>
        <Prln (0 1) '345678'> 
        <Prfe 3 '1234567'>
        <Prla 3 '123456'>
        <Prfe 1 2> 
        <Prla 3 1 2 3 '567'> 
//  neot
        <Prfe '123'>
        <Prla '123'>;
}

$FUNC Prfe
{
    e.E = <Prow First e.E>;
}

$FUNC Prla
{
    e.E = <Prow Last e.E>;
}

$FUNC Prow
{
    s.F e.E = <Proutm s.F ', whod=' e.E '  wyh=' < s.F e.E>>;
}

$FUNC Prln
{
    e.E = <Prout ' lengr,lengw: whod=' e.E '  wyh-r=' <LengR e.E> '  wyh-w=' <LengW e.E>>;
}

$END.
