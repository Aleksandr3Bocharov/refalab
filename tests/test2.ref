$STARET TEST2;

$ENTRY Go;
$EXTERN FOpen, FClose, FGetS, FPutS, Rename, Remove_File;
$EXTERN Print, Prout, FtoChar, ChartoF, FuncTab;
$EMPTY ffff;

$FUNC Go
{
    =
        <FuncTab &Prout> 
        < <ChartoF 'prout'> ' eto prout'> 
        < <ChartoF 'PROUT'> ' eto PROUT'> 
*       <FOpen 'r' 10 'bb'>     !!  neot  !!
        <FOpen 'w' 0 'lala.tes'> 
        <FPutS 0 ' str 1\n'>
        <FPutS 0 ' str 2\n'>
        <FClose 0> 
        <FOpen 'a' 1 'lala.tes'> 
        <FPutS 1  ' str 3\n'> 
        <FClose 1> 
        <Rename 'lala.tes' 0 'lala.tos'> 
        <FOpen 'r' 4 'lala.tos'> 
        <Print <FGetS 4>>
        <Print <FGetS 4>> 
        <Print <FGetS 4>> 
        <Print <FGetS 4>>
        <FClose 4> 
        <Prout ' d.b. ffff: ' <FtoChar &ffff>> 
        <FuncTab &tttt> 
        < <ChartoF 'tttt'> 'werno'> 
        <Remove_File 'lala.tos'>;
}

$FUNC tttt
{
    E.E = <Prout E.E>;
}

$END.
