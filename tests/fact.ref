$START FACT;

$ENTRY Go;
$EXTERN Numb, Symb, Cvd, First;
$EXTERN Mul;
$EXTERN Prouts, Card, M1;

$FUNC Go
{
    = <Fact <Numb <Card ' Give a number: '>>>;
}

$FUNC Fact
{
    0 = ; 
    e.N =
        <Pr e.N '!=' <Cvd <F e.N>>> 
        <Go>;
}

$FUNC F 
{  
    1 = 1;
    e.N = <Mul (e.N) <F <M1 e.N>>>;
}

$FUNC Pr 
{
    = ;
    e.S = <Pr1 <First 80 e.S>>;
}

$FUNC Pr1
{
    (e.S) e.E =
        <Prouts e.S>
        <Pr e.E>;
    '*' e.S = <Prouts e.S>;
}

$END.
