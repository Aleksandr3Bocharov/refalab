$START FACT;

$ENTRY Go;
$EXTERN Numb, Symb, Cvd, First;
$EXTERN Mul;
$EXTERN Prouts, Card, M1;

$FUNC Go
{
    = <Fact <Numb <Card ' Give a number: '>>>;
}

$FUNC Fact
{
    0 = ; 
    E.N =
        <Pr E.N '!=' <Cvd <F E.N>>> 
        <Go>;
}

$FUNC F 
{  
    1 = 1;
    E.N = <Mul (E.N) <F <M1 E.N>>>;
}

$FUNC Pr 
{
    = ;
    E.S = <Pr1 <First 80 E.S>>;
}

$FUNC Pr1
{
    (E.S) E.E =
        <Prouts E.S>
        <Pr E.E>;
    '*' E.S = <Prouts E.S>;
}

    END
