$START TEST0;

$ENTRY Go;
$EXTERN Add, Sub, Mul, Dr, M1, P1, Numb, Symb;
$EXTERN First, Last, LengR, LengW;
$EXTERN New, Wtr, Rdr, Ptr, Gtr, Swr;
$EXTERN Print, Prout, Proutm;
$EXTERN FOpen, FClose, FGetS, FPutS, Rename, Remove_File;
$EXTERN Br, Rp, Dg, DgAll, Cp;
$EMPTY Tra, Em1, Em2, Em3, Pus;
$SWAP Sw;

$SPEC Bspe '2134' Pus;

$FUNC Div 
{
    e.N = <Div0 <Dr e.N>>;
}

$FUNC Div0
{
    e.N (e._) = e.N;
}

$FUNC Go 
{
    =
        <Prsw>
        <Prvv>
        <Prkop>
        <Dal1>
        <Prspe Pus 'as01a432l7l' Em3>;
}

*      prowerka  specifikacii
$FUNC Prspe
{
    e.E s(Em1 Em2 Em3).S = <Prout ' symbol-&em' s.S> <Prspe e.E>;
    s(:Bspe:).S e.K = <Prout ' symbol-b=' s.S> <Prspe e.K>;
    $RIGHT e.H s('l7').S = <Prout ' symbol-l=' s.S> <Prspe e.H>;
    s.S e.K = <Prout '  symbol=' s.S> <Prspe e.K>;
    = ;
}

*      prowerka Mul, P1, Lengr, Lengw, First, Last, Numb, Symb, Add, M1, Sub
$FUNC Dal1
{
    =
        <Prmu (126) 2>
        <Prmu (16777216) 64> 
        <Prmu (4294967295) 1> 
        <Prmu (16777216) 512>   
        <Prdl (65536) 4>
        <Prdl (65536) 777> 
*       <Prdl (1) 0>       neot
        <Prp1 4>
        <Prp1 65536>
        <Prp1 128> 
*       <Prp1 4294967295>      neot
        <Dal>;
}

$FUNC Dal
{
    = 
        <Prln 0 1 '345678'>
        <Prln (0 1) '345678'>
        <Prfe 3 '1234567'>
        <Prla 3 '123456'>
        <Prfe 1 2> 
        <Prla 3 1 2 3 '567'> 
*       <Prfe '123'>          neot
*       <Prla '123'>          neot
        <Prnu '125'>
        <Prnu '76666'>
        <Prnu '4294967295'> 
*       <Prnu '4394967295'>                 neot
        <Prnu '-45'> 
        <Prsy 5678>
        <Prsy 4294967295> 
        <Prad (128) 456>
        <Prad (4294967295) 2>
        <Prm1 3>
        <Prm1 128>
        <Prm1 4294967295> 
        <Prsu (4294967295) 2>
        <Prsu (2) 456>;
}

$FUNC Prmu
{
    e.N = <Prow Mul e.N>;
}

$FUNC Prnu
{
    e.N = <Prow Numb e.N>;
}

$FUNC Prsy
{
    e.N = <Prow Symb e.N>;
}

$FUNC Prad
{
    e.N = <Prow Add e.N>;
}

$FUNC Prsu
{
    e.N = <Prow Sub e.N>;
}

$FUNC Prm1
{
    e.N = <Prow M1 e.N>;
}

$FUNC Prdl
{
    e.N = <Prow Div e.N>;
}

$FUNC Prp1
{
    e.N = <Prow P1 e.N>;
}

$FUNC Prfe
{
    e.E = <Prow First e.E>;
}

$FUNC Prla
{
    e.E = <Prow Last e.E>;
}

$FUNC Prow
{
    s.F e.E = <Proutm s.F ', whod=' e.E '  wyh=' < s.F e.E>>;
}

$FUNC Prkop 
{  
    = 
        <Br 'cc' '=' 123>
        <Br 'mmm' '=' '345'>
        <Rp 'mmm' '=' '879'>
        <Dg 'mmm'>
        <Cp 'cc'>
        <DgAll>
        <Br Tra '=' '765'>
        <Rp Tra '=' 16777215>
        <Dg Tra>;
}

$FUNC Prvv
{   
    =
        <FOpen 'w' 0 'lala.put'>
        <FPutS 0 ' str 1\n'>
        <FPutS 0 ' str 2\n'>
        <FClose 0>
        <FOpen 'a' 1 'lala.put'> 
        <FPutS 1 ' str 3\n'>
        <FClose 1> 
        <Rename 'lala.put' 0 'lala.get'>
        <FOpen 'r' 4 'lala.get'>
        <Print <FGetS 4>>
        <Print <FGetS 4>>
        <Print <FGetS 4>>
        <FClose 4>
        <Remove_File 'lala.get'>;
}

$FUNC Prsw
{   
    = 
        <Sw1 <New 123456>>
        <Wtr Sw 123456>
        <Ptr Sw '0'>
        <Rdr Sw>
        <Gtr Sw>;
}

$FUNC Sw1 
{
    r.X = 
        <Ptr r.X 2>
        <Rdr r.X>
        <Wtr r.X 12>
        <Sw2 r.X>;
}

$FUNC Sw2 
{
    r.X =
        <Ptr r.X 3>
        <Rdr r.X>
        <Gtr r.X>
        <Swr r.X '0' 4294967295 '0'>
        <Prout <Rdr r.X>>;
}

$FUNC Prln
{
    e.E = <Prout ' lengr,lengw: whod=' e.E '  wyh-r=' <LengR e.E> '  wyh-w=' <LengW e.E>>;
}

$END.
