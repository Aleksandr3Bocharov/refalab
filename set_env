# *******************************************************************
# set_env
# set environment variables for RefalAB
# *******************************************************************

# Get the current directory where the script is located
CURRENT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Check for spaces in the folder path
case "$CURRENT_DIR" in
    *" "*)
        echo "============================================================"
        echo "[ERROR] The folder path contains spaces!"
        echo "Current path: $CURRENT_DIR"
        echo ""
        echo "Please rename the folders or move the project to a path"
        echo "without spaces (for example, /home/user/refalab/)."
        echo "============================================================"
        return 1 2>/dev/null || exit 1
        ;;
esac

# If there are no spaces, set environment variables
export REFALABBIN=$CURRENT_DIR/bin
export REFALABLIB=$CURRENT_DIR/lib
export REFALABINCLUDE=$CURRENT_DIR/include
export REFALABLLFLAGS="-O2 -Wno-override-module"
export REFALABLLFLAGS_DBG="-O0 -g -Wno-override-module"
export REFALABCFLAGS="-pipe -Wall -O2 -DPOSIX"
export REFALABCFLAGS_DBG="-pipe -Wall -O0 -g -Dmdebug -DPOSIX"
export REFALABLFLAGS="$CURRENT_DIR/lib/obj/refalab_initiator.o -L$CURRENT_DIR/lib -lrefalab"
export REFALABLFLAGS_DBG="$CURRENT_DIR/lib/obj/refalab_initiator_dbg.o -L$CURRENT_DIR/lib -lrefalab_dbg"
export REFALABLFLAGS_DEBUGGER="$CURRENT_DIR/lib/obj/refalab_debugger.o -L$CURRENT_DIR/lib -lrefalab"
export REFALABLFLAGS_DEBUGGER_DBG="$CURRENT_DIR/lib/obj/refalab_debugger_dbg.o -L$CURRENT_DIR/lib -lrefalab_dbg"

# Ask the user if they want to add the bin folder to PATH
echo ""
printf "Do you want to add the bin folder to your PATH? (y/N): "
read -r answer

case "$answer" in
    [yY][eE][sS]|[yY])
        # Check if already in PATH
        case ":$PATH:" in
            *":$CURRENT_DIR/bin:"*)
                echo "[INFO] Path to bin folder is already in PATH."
                ;;
            *)
                # Add to current session
                export PATH="$CURRENT_DIR/bin:$PATH"
                echo "[SUCCESS] Path to bin folder added to current session PATH."
                                ;;
        esac
        ;;
    *)
        echo "[INFO] Skipping PATH modification."
        ;;
esac

echo "============================================================"
echo "[SUCCESS] All environment variables for RefalAB are set!"
echo "[IMPORTANT] If you ran this script normally, use 'source ./set_env' to apply changes to current terminal."
echo "============================================================"

